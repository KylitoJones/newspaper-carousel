# Copy this file to ".env" and fill in your own values.
# .env is git-ignored and never leaves your computer.

BLUESKY_HANDLE=kanasjones.bsky.social
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Optional: which model writes the alt text (default claude-sonnet-5).
# claude-haiku-4-5 is cheaper/faster; claude-opus-4-8 reads fine print best.
ALT_MODEL=claude-sonnet-5
